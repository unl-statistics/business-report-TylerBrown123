distinct(slat, slon, elat, elon)
sum(tornado_paths$elat == 0 | tornado_paths$elon == 0)
# Basic Data Cleaning (making each tornado only appear once and grabbing only the useful columns)
library(tidyverse)
tornado_full_data <- read.csv("1950-2024_actual_tornadoes.csv")
tornado_paths <- tornado_full_data |>
distinct(slat, slon, elat, elon)
library(ggplot2)
# create a new column to flag missing end coordinates
tornado_paths <- tornado_paths |>
mutate(end_missing = (elat == 0 | elon == 0))
# scatter plot of start locations colored by missing end
ggplot(tornado_paths, aes(x = slon, y = slat, color = end_missing)) +
geom_point(alpha = 0.5) +
scale_color_manual(values = c("FALSE" = "blue", "TRUE" = "red"),
labels = c("Has end", "End = 0")) +
labs(title = "Tornado Start Locations: End Coordinates Missing vs Present",
x = "Start Longitude", y = "Start Latitude", color = "End coordinates") +
theme_minimal()
tornado_paths
